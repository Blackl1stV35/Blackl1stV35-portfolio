# Copy this file to .env.local and fill in your values

# Admin auth — generate with: openssl rand -base64 32
ADMIN_TOKEN=your-secret-token-here

# GitHub API — create at https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# Vercel Blob — auto-generated when you run: npx vercel blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Formspree — get from https://formspree.io (free tier)
# Replace YOUR_FORM_ID in src/app/contact/page.tsx
